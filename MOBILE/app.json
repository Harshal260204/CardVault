{
  "expo": {
    "name": "CardVault",
    "slug": "cardvault-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "cardvault",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1E3A5F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cardvault.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1E3A5F"
      },
      "package": "com.cardvault.mobile",
      "usesCleartextTraffic": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow CardVault to access photos for business card scanning."
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-build-properties",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1E3A5F"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
