# API host WITHOUT /api/v1 — must be reachable from your phone/emulator
#
# Physical device (Expo Go): use your PC's LAN IP (same Wi‑Fi as phone)
#   EXPO_PUBLIC_API_URL=http://192.168.0.106:8000
# Android emulator:
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:8000
# iOS simulator:
#   EXPO_PUBLIC_API_URL=http://localhost:8000
#
# Do NOT use localhost on a real phone — it points at the phone, not your PC.
EXPO_PUBLIC_API_URL=http://192.168.0.106:8000
