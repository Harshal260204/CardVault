# ─── Server ────────────────────────────────────────────────────
PORT=8000
CORS_ORIGINS=http://localhost:3000
NODE_ENV=development

# ─── PostgreSQL (required) ─────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cardvault

# Supabase (production): use pooled connection string
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# ─── Redis / BullMQ (optional locally) ───────────────────────────
# REDIS_URL=redis://localhost:6379

# ─── Supabase Storage (optional; default STORAGE_DRIVER=local) ─
# STORAGE_DRIVER=local
# STORAGE_DRIVER=supabase
# SUPABASE_URL=https://[ref].supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=card-images

# ─── Auth (JWT) ────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_SECRET=dev-access-secret-min-32-characters-long
JWT_REFRESH_SECRET=dev-refresh-secret-min-32-characters-long
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=2592000

# RS256 (P3.1) — set JWT_ALGORITHM=RS256 and provide keys
# JWT_ACCESS_PRIVATE_KEY_PATH=./secrets/jwt-access-private.pem
# JWT_ACCESS_PUBLIC_KEY_PATH=./secrets/jwt-access-public.pem

# ─── OCR (Google Cloud Vision — default) ───────────────────────
OCR_PROVIDER=google
GOOGLE_VISION_KEY_PATH=./src/secure/cardvault-ocr-4a8c0f17725e.json
# GOOGLE_APPLICATION_CREDENTIALS=./src/secure/cardvault-ocr-4a8c0f17725e.json
GOOGLE_VISION_TIMEOUT_MS=60000

# Legacy local PaddleOCR sidecar (only when OCR_PROVIDER=paddle):
# OCR_PROVIDER=paddle
# PADDLE_OCR_URL=http://127.0.0.1:8001
# PADDLE_OCR_TIMEOUT_MS=120000

# ─── Uploads & exports ─────────────────────────────────────────
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
API_PUBLIC_URL=http://localhost:8000

# ─── Sentry (P3.2) ─────────────────────────────────────────────
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Stripe billing ────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO=price_xxx
# WEB_APP_URL=http://localhost:3000
